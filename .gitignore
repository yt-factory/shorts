# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Media files (too large for git)
files/input/*
files/output/*
!files/input/.gitkeep
!files/output/.gitkeep

# Editor
.idea/
.vscode/
*.swp

# Debug images (generated during processing)
*_debug.png

# Claude Code local config
.claude/
